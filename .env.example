# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs (créés dans le dashboard Stripe pour les 3 tiers)
STRIPE_PRICE_S=
STRIPE_PRICE_M=
STRIPE_PRICE_L=

# --- OpenAI (image editing via gpt-image-1) ---
# Generate a key at https://platform.openai.com/api-keys with image-edit access.
OPENAI_API_KEY=

# Optional overrides — sensible STR defaults baked into the code.
#   OPENAI_IMAGE_PROMPT    French prompt sent on every edit. Default targets a
#                          'photographe immobilier professionnel' style for STR.
#   OPENAI_IMAGE_SIZE      "auto" | "1024x1024" | "1024x1536" | "1536x1024"
#   OPENAI_IMAGE_QUALITY   "auto" | "low" | "medium" | "high"
OPENAI_IMAGE_PROMPT=
OPENAI_IMAGE_SIZE=auto
OPENAI_IMAGE_QUALITY=high

# --- Cron / Internal ---
CRON_SECRET=

# --- Delivery delay ---
# Number of business days between "upload completed" and customer email.
# Set to 0 to deliver as soon as processing finishes (test / dev mode).
# Production value: 2 (= "livré sous 48h ouvrées" in French commerce-speak).
DELIVERY_DELAY_BUSINESS_DAYS=2

# --- Order tokens (HMAC) ---
# `openssl rand -hex 32`. Used to sign the order_session cookie + email links.
ORDER_TOKEN_SECRET=

# --- Email (SendGrid) ---
# The sender address must be verified in SendGrid (Settings → Sender
# Authentication: either domain auth on immoscan.fr or single-sender on
# contact@immoscan.fr).
SENDGRID_API_KEY=
EMAIL_FROM=contact@immoscan.fr
EMAIL_FROM_NAME="Geoffrey · Immoscan"

# --- Admin ---
ADMIN_EMAILS=you@example.com

# --- ActiveCampaign (CRM tagging on purchase) ---
# Find these under Settings → Developer in your ActiveCampaign account.
#   ACTIVE_CAMPAIGN_URL          e.g. https://yourname.api-us1.com (no trailing slash)
#   ACTIVE_CAMPAIGN_API_KEY      personal API key
#   ACTIVE_CAMPAIGN_BUYER_TAG_ID id of the tag applied on every paid order (default 130)
ACTIVE_CAMPAIGN_URL=
ACTIVE_CAMPAIGN_API_KEY=
ACTIVE_CAMPAIGN_BUYER_TAG_ID=130
