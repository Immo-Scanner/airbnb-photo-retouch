# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs (créés dans le dashboard Stripe pour les 3 tiers)
STRIPE_PRICE_S=
STRIPE_PRICE_M=
STRIPE_PRICE_L=

# --- AutoEnhance ---
AUTOENHANCE_API_KEY=
AUTOENHANCE_DEV_MODE=true
AUTOENHANCE_WEBHOOK_TOKEN=

# Enhancement tuning (STR / Airbnb defaults applied in code; override here only
# if you want to test alternatives). Documented values:
#   AUTOENHANCE_AI_VERSION    "5.x" | "4.x" | specific (e.g. "5.2")
#   AUTOENHANCE_ENHANCE_TYPE  "warm" | "neutral" | "modern" | "property"
#   AUTOENHANCE_CLOUD_TYPE    "CLEAR" | "LOW_CLOUD" | "HIGH_CLOUD"
#   AUTOENHANCE_WINDOW_PULL   "NONE" | "ONLY_WINDOWS" | "WINDOWS_WITH_SKIES"
#   AUTOENHANCE_RESTAGE       "true" enables in-painting (fireplace lit, grass
#                             greened, photographer + TV black-out). May consume
#                             premium credits — leave off until billing is OK.
AUTOENHANCE_AI_VERSION=5.x
AUTOENHANCE_ENHANCE_TYPE=warm
AUTOENHANCE_CLOUD_TYPE=LOW_CLOUD
AUTOENHANCE_WINDOW_PULL=WINDOWS_WITH_SKIES
AUTOENHANCE_RESTAGE=false

# --- Cron / Internal ---
CRON_SECRET=

# --- Delivery delay ---
# Business hours to wait between "upload completed" and email delivery.
# Set to 0 to deliver as soon as AutoEnhance finishes (test / dev mode).
# Production value: 48 (mimics the human-photographer turnaround).
DELIVERY_DELAY_HOURS=48

# --- Order tokens (HMAC) ---
# `openssl rand -hex 32`. Used to sign the order_session cookie + email links.
ORDER_TOKEN_SECRET=

# --- Email (SendGrid) ---
# The sender address must be verified in SendGrid (Settings → Sender
# Authentication: either domain auth on immoscan.fr or single-sender on
# contact@immoscan.fr).
SENDGRID_API_KEY=
EMAIL_FROM=contact@immoscan.fr
EMAIL_FROM_NAME="Geoffrey · Immoscan"

# --- Admin ---
ADMIN_EMAILS=you@example.com
