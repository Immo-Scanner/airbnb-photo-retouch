# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs (créés dans le dashboard Stripe pour les 3 tiers)
STRIPE_PRICE_S=
STRIPE_PRICE_M=
STRIPE_PRICE_L=

# --- OpenAI (image editing via gpt-image-1) ---
# Generate a key at https://platform.openai.com/api-keys with image-edit access.
OPENAI_API_KEY=

# Optional overrides — sensible STR defaults baked into the code.
#   OPENAI_IMAGE_PROMPT    French prompt sent on every edit. Default targets a
#                          'photographe immobilier professionnel' style for STR.
#   OPENAI_IMAGE_SIZE      "auto" | "1024x1024" | "1024x1536" | "1536x1024"
#   OPENAI_IMAGE_QUALITY   "auto" | "low" | "medium" | "high"
OPENAI_IMAGE_PROMPT=
OPENAI_IMAGE_SIZE=auto
OPENAI_IMAGE_QUALITY=high

# --- Cron / Internal ---
CRON_SECRET=

# --- Delivery delay ---
# Business hours to wait between "upload completed" and email delivery.
# Set to 0 to deliver as soon as AutoEnhance finishes (test / dev mode).
# Production value: 48 (mimics the human-photographer turnaround).
DELIVERY_DELAY_HOURS=48

# --- Order tokens (HMAC) ---
# `openssl rand -hex 32`. Used to sign the order_session cookie + email links.
ORDER_TOKEN_SECRET=

# --- Email (SendGrid) ---
# The sender address must be verified in SendGrid (Settings → Sender
# Authentication: either domain auth on immoscan.fr or single-sender on
# contact@immoscan.fr).
SENDGRID_API_KEY=
EMAIL_FROM=contact@immoscan.fr
EMAIL_FROM_NAME="Geoffrey · Immoscan"

# --- Admin ---
ADMIN_EMAILS=you@example.com
